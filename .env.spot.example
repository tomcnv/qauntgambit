# Spot bot example configuration
# Copy to .env.spot and replace placeholders before running spot flows.

BOT_ID=00000000-0000-0000-0000-000000000001
TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_BOT_ID=00000000-0000-0000-0000-000000000001

MARKET_TYPE=spot
TRADING_MODE=paper
ACTIVE_EXCHANGE=bybit
EXCHANGE=bybit
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
ORDERBOOK_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
MARKET_DATA_PROVIDER=ccxt
MARKET_DATA_STREAM=events:market_data:bybit

BYBIT_API_KEY=
BYBIT_SECRET_KEY=
BYBIT_TESTNET=true
BYBIT_DEMO=true
EXCHANGE_ACCOUNT_ID=00000000-0000-0000-0000-000000000001
EXCHANGE_SECRET_ID=

BOT_DB_HOST=localhost
BOT_DB_PORT=5432
BOT_DB_NAME=quantgambit_bot
BOT_DB_USER=quantgambit
BOT_DB_PASSWORD=quantgambit_pw
BOT_TIMESCALE_URL=postgresql://quantgambit:quantgambit_pw@localhost:5432/quantgambit_bot

PLATFORM_DB_HOST=localhost
PLATFORM_DB_PORT=5432
PLATFORM_DB_NAME=platform_db
PLATFORM_DB_USER=platform
PLATFORM_DB_PASSWORD=platform_pw

REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

FORCE_PROFILE_ID=spot_accumulation
ENABLE_SPOT_PROFILES=true
PREDICTION_PROVIDER=onnx
PREDICTION_MODEL_PATH=models/spot_1h_50bps.onnx
PREDICTION_MODEL_CONFIG=models/spot_1h_50bps.json

MAX_CAPITAL_USD=10000
TRADING_CAPITAL_USD=10000
PAPER_EQUITY=10000
EXECUTION_PROVIDER=ccxt
