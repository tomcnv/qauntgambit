{
  "name": "deeptrader-backend",
  "version": "1.0.0",
  "description": "veloxio autonomous trading bot backend service",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test tests/unit/*.test.js",
    "start:all": "cd .. && ./start-all.sh",
    "stop:all": "cd .. && ./stop-all.sh",
    "start:backend": "node server.js",
    "start:python": "cd ../quantgambit-python && ./venv311/bin/python -m quantgambit.api.app",
    "start:monitoring": "node -e \"console.log('Legacy monitoring API is disabled; use QuantGambit API.')\""
  },
  "keywords": [
    "trading",
    "bot",
    "crypto",
    "ai",
    "deepseek"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.990.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "ccxt": "^4.5.19",
    "cluster": "^0.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "protobufjs": "^7.5.4",
    "qrcode": "^1.5.3",
    "redis": "^5.9.0",
    "sentiment": "^5.0.2",
    "speakeasy": "^2.0.0",
    "technicalindicators": "^3.1.0",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
