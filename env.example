# ============================================================================
# DeepTrader / QuantGambit Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp env.example .env
# ============================================================================

# ============ Infrastructure Host Configuration ============
# Default infrastructure host (used when specific hosts are not set)
# All services default to localhost if not overridden
INFRA_HOST=localhost

# ============ Redis Configuration ============
# Redis connection URL (preferred method)
REDIS_URL=redis://localhost:6379

# OR use individual components:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Alternative Redis URL for bot services (overrides REDIS_URL if set)
BOT_REDIS_URL=

# ============ Platform/Dashboard Database Configuration ============
# Platform database (PostgreSQL) - used by dashboard and backend
DB_HOST=localhost
DB_PORT=5432
DB_NAME=platform_db
DB_USER=platform
DB_PASSWORD=platform_pw

# Alternative names for platform database (all map to same connection)
PLATFORM_DB_HOST=localhost
PLATFORM_DB_PORT=5432
PLATFORM_DB_NAME=platform_db
PLATFORM_DB_USER=platform
PLATFORM_DB_PASSWORD=platform_pw

# Dashboard-specific database settings (fallback to platform DB if not set)
DASHBOARD_DB_HOST=localhost
DASHBOARD_DB_PORT=5432
DASHBOARD_DB_NAME=platform_db
DASHBOARD_DB_USER=platform
DASHBOARD_DB_PASSWORD=platform_pw

# ============ Bot/Timescale Database Configuration ============
# Bot database (TimescaleDB) - used by trading runtime
BOT_DB_HOST=localhost
BOT_DB_PORT=5433
BOT_DB_NAME=quantgambit_bot
BOT_DB_USER=quantgambit
BOT_DB_PASSWORD=quantgambit_pw

# Bot database connection string (alternative to individual components)
BOT_TIMESCALE_URL=postgresql://quantgambit:quantgambit_pw@localhost:5433/quantgambit_bot

# ============ Backend API Configuration ============
NODE_ENV=development
PORT=3001
ALLOW_UNAUTHENTICATED=true

# ============ QuantGambit API Configuration ============
API_PORT=8080
PYTHONUNBUFFERED=1

# ============ Bot API Configuration (Python FastAPI) ============
# Port for the Bot API server (FastAPI) - serves research/backtesting endpoints
BOT_API_PORT=3002
# Host address for the Bot API server
BOT_API_HOST=0.0.0.0

# ============ CORS Configuration ============
# Comma-separated list of allowed origins for Bot API (empty allows all in development)
CORS_ALLOW_ORIGINS=

# ============ Exchange Credentials ============
# OKX Credentials
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
OKX_TESTNET=true

# Binance Credentials (optional)
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=false

# Bybit Credentials (optional)
BYBIT_API_KEY=
BYBIT_SECRET_KEY=
BYBIT_TESTNET=false

# ============ Active Exchange ============
# Which exchange to trade on: okx, binance, bybit
ACTIVE_EXCHANGE=okx

# ============ Bot Identity ============
# These must match your database records
EXCHANGE_ACCOUNT_ID=
BOT_ID=
BOT_NAME=
TENANT_ID=

# ============ Trading Configuration ============
TRADING_MODE=paper
EXECUTION_PROVIDER=none
ORDERBOOK_SOURCE=external
TRADE_SOURCE=external
MARKET_TYPE=perp
MARGIN_MODE=isolated
EXECUTION_SYNC_INTERVAL_SEC=20
EXECUTION_SYNC_LOOKBACK_SEC=300
EXECUTION_SYNC_OVERLAP_SEC=30
EXECUTION_SYNC_LIMIT=200

# ============ Market Data Service Configuration ============
# Exchange-specific market data streams
EXCHANGE=okx
SYMBOLS=BTC-USDT-SWAP,ETH-USDT-SWAP,SOL-USDT-SWAP
PUBLISH_MODE=both
ORDERBOOK_EVENT_STREAM=events:orderbook_feed:okx
TRADE_EVENT_STREAM=events:trades:okx
MARKET_DATA_STREAM=events:market_data:okx
TRADES_ENABLED=true
TICKERS_ENABLED=false

# ============ Control Manager Configuration ============
CONTROL_GROUP=quantgambit_control
CONTROL_CONSUMER=control_manager
CONTROL_ENABLE_LAUNCH=true
CONTROL_REQUIRE_HEALTH=false

# ============ Guardian Configuration ============
GUARDIAN_POLL_SEC=5
GUARDIAN_REFRESH_SEC=60
GUARDIAN_MAX_AGE_SEC=0

# ============ Position Guard Configuration ============
POSITION_GUARD_ENABLED=true
POSITION_GUARD_INTERVAL_SEC=1.0
POSITION_GUARD_MAX_AGE_SEC=0.0
POSITION_GUARD_TRAILING_BPS=30.0
POSITION_GUARD_TRAILING_ACTIVATION_BPS=15.0
POSITION_GUARD_TRAILING_MIN_HOLD_SEC=0.0
POSITION_GUARD_BREAKEVEN_ACTIVATION_BPS=10.0
POSITION_GUARD_BREAKEVEN_BUFFER_BPS=2.0
POSITION_GUARD_BREAKEVEN_MIN_HOLD_SEC=0.0
POSITION_GUARD_MIN_PROFIT_BUFFER_BPS=5.0
POSITION_GUARD_FEE_CONFIG=bybit_regular

# ============ Exit Signal Configuration ============
# Minimum hold time before strategic exits (non-safety) are allowed
EXIT_SIGNAL_MIN_HOLD_SEC=0.0
# Enforce fee-aware gating for exit signals (blocks exits below fee breakeven)
EXIT_SIGNAL_ENFORCE_FEE_CHECK=true

# ============ Slippage Estimation ============
# Scale slippage estimates to better match live fills (1.0 = no scaling)
SLIPPAGE_MODEL_MULTIPLIER=1.0
# Optional override for symbol floor (bps) used by the slippage model
SLIPPAGE_MODEL_FLOOR_BPS=0.0
# Multiplier applied to SnapshotBuilder expected_fill_slippage_bps (entry only)
SNAPSHOT_SLIPPAGE_MULTIPLIER=1.0
# Minimum slippage floor for SnapshotBuilder estimates (entry only)
SNAPSHOT_MIN_SLIPPAGE_BPS=0.0
# EMA smoothing for observed slippage from live fills (0-1, higher = faster)
SLIPPAGE_EMA_ALPHA=0.2

# ============ Backtesting & Bot Integration Configuration ============
# Enforce configuration parity between backtest and live trading modes
# When enabled, validates that backtest configurations match live settings
# Set to "false" to allow divergent configurations (not recommended for production)
BACKTEST_PARITY_MODE=true

# Enable warm start from live state for backtesting
# When enabled, backtests can initialize from the current live trading state
# Useful for testing strategy changes against recent market conditions
BACKTEST_WARM_START_ENABLED=false

# Warm start state staleness threshold in seconds
# If the live state is older than this threshold, warm start will be rejected
# Prevents backtests from starting with outdated state data
BACKTEST_WARM_START_STALE_SEC=300.0

# Enable decision recording for signal pipeline
# When enabled, records all trading decisions for analysis and debugging
# Captures signal generation, filtering, and execution decisions
DECISION_RECORDER_ENABLED=true

# ============ Notes ============
# - All database and Redis connections default to localhost
# - Individual service hosts can be overridden with specific env vars
# - Connection strings (REDIS_URL, BOT_TIMESCALE_URL) take precedence over individual components
# - Platform DB and Dashboard DB are typically the same database
# - Bot DB is a separate TimescaleDB instance for trading telemetry

# ============ Unified Confirmation Policy ============
# Keep shadow mode first for safe rollout; switch to enforce after validation.
ENABLE_UNIFIED_CONFIRMATION_POLICY=true
ENABLE_LEGACY_CONFIRMATION_ADAPTER=true
CONFIRMATION_POLICY_MODE=shadow
CONFIRMATION_POLICY_VERSION=v1
CONFIRMATION_POLICY_ENTRY_MIN_CONFIDENCE=0.64
CONFIRMATION_POLICY_ENTRY_MIN_VOTES=2
CONFIRMATION_POLICY_EXIT_MIN_CONFIDENCE=0.50
CONFIRMATION_POLICY_EXIT_MIN_VOTES=2
CONFIRMATION_POLICY_WEIGHT_TREND=1.0
CONFIRMATION_POLICY_WEIGHT_FLOW=1.0
CONFIRMATION_POLICY_WEIGHT_RISK_STABILITY=1.0

# Strategy overrides tuned to protect momentum/trend winners from premature non-emergency exits.
# Trend/momentum: higher trend weight + stricter exit confirmation.
# Mean-reversion/microstructure: keep baseline behavior to avoid excessive lag.
CONFIRMATION_POLICY_STRATEGY_OVERRIDES_JSON={"trend_pullback":{"weights":{"trend":1.5,"flow":1.0,"risk_stability":0.8},"thresholds":{"entry_min_confidence":0.66,"entry_min_votes":2,"exit_min_confidence":0.62,"exit_min_votes":3}},"breakout_scalp":{"weights":{"trend":1.4,"flow":1.1,"risk_stability":0.8},"thresholds":{"entry_min_confidence":0.66,"entry_min_votes":2,"exit_min_confidence":0.60,"exit_min_votes":3}},"high_vol_breakout":{"weights":{"trend":1.4,"flow":1.1,"risk_stability":0.8},"thresholds":{"entry_min_confidence":0.66,"entry_min_votes":2,"exit_min_confidence":0.60,"exit_min_votes":3}},"us_open_momentum":{"weights":{"trend":1.4,"flow":1.1,"risk_stability":0.8},"thresholds":{"entry_min_confidence":0.65,"entry_min_votes":2,"exit_min_confidence":0.60,"exit_min_votes":3}},"vol_expansion":{"weights":{"trend":1.3,"flow":1.1,"risk_stability":0.9},"thresholds":{"entry_min_confidence":0.65,"entry_min_votes":2,"exit_min_confidence":0.58,"exit_min_votes":3}}}

# ============ Prediction Quality / Readiness Gates ============
PREDICTION_GATE_ENFORCE_SCORE_METRICS=true
PREDICTION_GATE_SCORE_FAIL_CLOSED=false
PREDICTION_SCORE_GATE_ENABLED=false
PREDICTION_SCORE_FAIL_CLOSED=false
PREDICTION_SCORE_MIN_SAMPLES=200
PREDICTION_SCORE_MIN_ML_SCORE=60.0
PREDICTION_SCORE_MIN_EXACT_ACCURACY=0.50
PREDICTION_SCORE_MIN_DIRECTIONAL_ACCURACY=0.50
PREDICTION_SCORE_MIN_DIRECTIONAL_ACCURACY_LONG=
PREDICTION_SCORE_MIN_DIRECTIONAL_ACCURACY_SHORT=
PREDICTION_SCORE_MAX_ECE=0.20
PREDICTION_SCORE_MAX_ECE_LONG=
PREDICTION_SCORE_MAX_ECE_SHORT=
CONFIRMATION_READY_MAX_ROWS=20000
CONFIRMATION_READY_QUERY_TIMEOUT_SEC=2.0
