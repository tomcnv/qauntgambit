NODE_ENV=production
DEEPTRADER_ENV=${secret_environment}
AWS_REGION=${aws_region}
SECRETS_PROVIDER=aws
AUTH_MODE=${auth_mode}
ALLOW_UNAUTHENTICATED=${allow_unauthenticated}
AUTH_JWT_SECRET=${jwt_secret}
JWT_SECRET=${jwt_secret}

PLATFORM_DB_USER=${platform_db_user}
PLATFORM_DB_PASSWORD=${platform_db_password}
PLATFORM_DB_NAME=${platform_db_name}
PLATFORM_DB_HOST=postgres_platform
PLATFORM_DB_PORT=5432

BOT_DB_USER=${bot_db_user}
BOT_DB_PASSWORD=${bot_db_password}
BOT_DB_NAME=${bot_db_name}
BOT_DB_HOST=timescale_bot
BOT_DB_PORT=5432

DB_HOST=postgres_platform
DB_PORT=5432
DB_USER=${platform_db_user}
DB_PASSWORD=${platform_db_password}
DB_NAME=${platform_db_name}
DB_SSL=false

DASHBOARD_DB_HOST=postgres_platform
DASHBOARD_DB_PORT=5432
DASHBOARD_DB_NAME=${platform_db_name}
DASHBOARD_DB_USER=${platform_db_user}
DASHBOARD_DB_PASSWORD=${platform_db_password}
DASHBOARD_DB_SSL=false

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
BOT_REDIS_URL=redis://redis:6379

BOT_TIMESCALE_URL=postgresql://${bot_db_user}:${bot_db_password}@timescale_bot:5432/${bot_db_name}
API_PORT=${bot_api_port}
PORT=${core_api_port}
PYTHONUNBUFFERED=1
PYTHON_API_URL=http://quantgambit-api:${bot_api_port}

ACTIVE_EXCHANGE=${active_exchange}
BYBIT_DEMO=${bybit_demo}
BYBIT_TESTNET=${bybit_testnet}
ORDER_UPDATES_DEMO=${order_updates_demo}
ORDERBOOK_SYMBOLS=${orderbook_symbols}
SYMBOLS=${symbols}

VITE_API_URL=https://${api_domain}/api
VITE_DASHBOARD_URL=https://${dashboard_domain}
VITE_LANDING_URL=https://${www_domain}
VITE_CORE_API_BASE_URL=https://${api_domain}/api
VITE_BOT_API_BASE_URL=https://${bot_domain}/api
VITE_WS_URL=wss://${api_domain}

COPILOT_LLM_PROVIDER=${copilot_llm_provider}
COPILOT_LLM_API_KEY=${copilot_llm_api_key}
COPILOT_LLM_BASE_URL=${copilot_llm_base_url}
COPILOT_LLM_MODEL=${copilot_llm_model}
