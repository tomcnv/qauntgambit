# QuantGambit Python Environment Variables
# Copy this file to .env and customize as needed
# Default values are provided for local development

# =============================================================================
# Bot API Configuration
# =============================================================================
# Port for the Bot API server (FastAPI)
BOT_API_PORT=3002
# Host address for the Bot API server
BOT_API_HOST=0.0.0.0

# =============================================================================
# Database Configuration (TimescaleDB/PostgreSQL)
# =============================================================================
# Database host address
BOT_DB_HOST=localhost
# Database port
BOT_DB_PORT=5432
# Database name
BOT_DB_NAME=platform_db
# Database user
BOT_DB_USER=platform
# Database password
BOT_DB_PASSWORD=platform_pw

# Alternative database connection variables (fallback order)
# DASHBOARD_DB_HOST, DASHBOARD_DB_PORT, DASHBOARD_DB_NAME, DASHBOARD_DB_USER, DASHBOARD_DB_PASSWORD
# DB_HOST, PLATFORM_DB_HOST

# TimescaleDB connection pool settings
TIMESCALE_POOL_MAX=5

# =============================================================================
# Redis Configuration
# =============================================================================
# Redis URL for bot operations (takes precedence)
BOT_REDIS_URL=redis://localhost:6379
# Fallback Redis URL
REDIS_URL=redis://localhost:6379

# =============================================================================
# Feature Flags
# =============================================================================
# Enable decision recording to TimescaleDB (default: true)
DECISION_RECORDER_ENABLED=true
# Batch size for decision recorder writes
DECISION_RECORDER_BATCH_SIZE=100
# Flush interval for decision recorder (seconds)
DECISION_RECORDER_FLUSH_INTERVAL_SEC=5.0

# Enable warm start for backtests (default: false)
BACKTEST_WARM_START_ENABLED=false
# Stale threshold for warm start data (seconds)
BACKTEST_WARM_START_STALE_SEC=300.0

# Enable parity mode for backtests (default: true)
BACKTEST_PARITY_MODE=true

# Include trades in TimescaleDB backtest results
BACKTEST_TIMESCALEDB_INCLUDE_TRADES=true
# Batch size for TimescaleDB backtest writes
BACKTEST_TIMESCALEDB_BATCH_SIZE=1000

# =============================================================================
# Trading Configuration
# =============================================================================
# Trading mode: live, paper, testnet
TRADING_MODE=paper
# Tenant identifier
TENANT_ID=default
# Bot identifier
BOT_ID=default
# Default tenant ID for API requests
DEFAULT_TENANT_ID=
# Default bot ID for API requests
DEFAULT_BOT_ID=

# Paper trading starting equity
PAPER_EQUITY=100000

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins (empty allows all in development)
CORS_ALLOW_ORIGINS=

# =============================================================================
# Control Manager Configuration
# =============================================================================
# Require health check before processing commands
CONTROL_REQUIRE_HEALTH=false
# Enable launcher functionality
CONTROL_ENABLE_LAUNCH=false
# Consumer group for control commands
CONTROL_GROUP=quantgambit_control
# Consumer name for control commands
CONTROL_CONSUMER=control_manager
# Command to launch runtime
RUNTIME_LAUNCH_CMD=pm2 restart quantgambit-runtime --update-env
# Command to stop runtime
RUNTIME_STOP_CMD=pm2 stop quantgambit-runtime

# =============================================================================
# Risk Worker Configuration
# =============================================================================
# Persist positions to snapshots
RISK_PERSIST_POSITIONS=false
# Interval for position snapshots (seconds)
RISK_POSITIONS_SNAPSHOT_INTERVAL_SEC=2.0
# Enable debug state logging
RISK_DEBUG_STATE=false

# =============================================================================
# Guardian Configuration
# =============================================================================
# Exchange account ID
EXCHANGE_ACCOUNT_ID=
# Exchange name (binance, bybit, etc.)
EXCHANGE=binance
# Use testnet endpoints
IS_TESTNET=false
# Exchange secret ID for credentials
EXCHANGE_SECRET_ID=
# Guardian poll interval (seconds)
GUARDIAN_POLL_SEC=5
# Account refresh interval (seconds)
GUARDIAN_REFRESH_SEC=60
# Maximum position age before alert (seconds, 0 = disabled)
GUARDIAN_MAX_AGE_SEC=0
# Trailing stop in basis points (0 = disabled)
GUARDIAN_TRAILING_BPS=0
