def get_profile_config(profile_id: str) -> dict:
    """
    Get configuration for a profile ID
    
    Returns:
        dict: Profile config if found, None if unconfigured
    
    Note: Currently returns None for unconfigured profiles (no-trade behavior).
          In Phase 2, could return DEFAULT_CONSERVATIVE_CONFIG as fallback.
    """
    return PROFILE_STRATEGY_CONFIG.get(profile_id)

